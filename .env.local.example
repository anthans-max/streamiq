# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required: powers the /api/chat and /api/analyze streaming endpoints
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend ─────────────────────────────────────────────────────────────────────
# Optional: if set, /api/contact sends an email notification on each form submission.
# 1. Sign up at resend.com and verify your sending domain (or use onboarding@resend.dev for testing)
# 2. Create an API key at resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=streamiq@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com
