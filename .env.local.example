# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required: powers the /api/chat and /api/analyze streaming endpoints
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable ───────────────────────────────────────────────────────────────────
# Required for /api/contact to save form submissions to a table
# Create a base at airtable.com with columns: Name, Organization, Role, Interest, Message, Timestamp
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_NAME=Inquiries

# ── Resend ────────────────────────────────────────────────────────────────────
# Required for /api/contact to send email notifications on new form submissions
# Sign up at resend.com and verify your domain
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=streamiq@yourdomain.com
NOTIFICATION_EMAIL=team@yourdomain.com
