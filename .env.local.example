# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required: powers the /api/chat and /api/analyze streaming endpoints
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ───────────────────────────────────────────────────────────────────
# Required for /api/contact to save form submissions to the `leads` table.
# 1. Create a project at supabase.com
# 2. In the SQL editor, run:
#    create table leads (
#      id uuid primary key default gen_random_uuid(),
#      name text,
#      organization text,
#      role text,
#      interest text,
#      message text,
#      created_at timestamptz default now()
#    );
# 3. Get NEXT_PUBLIC_SUPABASE_URL from Project Settings → API → Project URL
# 4. Get SUPABASE_SERVICE_ROLE_KEY from Project Settings → API → service_role key (keep secret)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend ─────────────────────────────────────────────────────────────────────
# Required for /api/contact to send email notifications on new form submissions.
# 1. Sign up at resend.com and verify your sending domain (or use onboarding@resend.dev for testing)
# 2. Create an API key at resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=streamiq@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com
